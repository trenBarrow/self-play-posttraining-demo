{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poster.local/schemas/raw_transaction.schema.json",
  "title": "Protocol-General Raw Transaction Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "protocol_family",
    "protocol_version",
    "platform_family",
    "sender",
    "target",
    "command",
    "timing",
    "transport",
    "provenance",
    "outcome",
    "correlation",
    "evaluation_context",
    "evidence",
    "native_state_snapshot",
    "native_fields"
  ],
  "properties": {
    "schema_version": {
      "const": "raw_transaction.v1"
    },
    "record_kind": {
      "const": "raw_transaction"
    },
    "protocol_family": {
      "type": "string",
      "minLength": 1
    },
    "protocol_version": {
      "type": ["string", "null"]
    },
    "platform_family": {
      "type": ["string", "null"]
    },
    "sender": {
      "$ref": "#/$defs/identity"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "command": {
      "anyOf": [
        { "$ref": "#/$defs/command" },
        { "type": "null" }
      ]
    },
    "timing": {
      "$ref": "#/$defs/transactionTiming"
    },
    "transport": {
      "$ref": "#/$defs/transactionTransport"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "outcome": {
      "anyOf": [
        { "$ref": "#/$defs/outcome" },
        { "type": "null" }
      ]
    },
    "correlation": {
      "$ref": "#/$defs/correlation"
    },
    "evaluation_context": {
      "$ref": "#/$defs/evaluationContext"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "native_state_snapshot": {
      "anyOf": [
        { "$ref": "#/$defs/nativeStateSnapshot" },
        { "type": "null" }
      ]
    },
    "native_fields": {
      "type": "object"
    }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_id", "role", "trust_score", "network_endpoint"],
      "properties": {
        "logical_id": { "type": "string", "minLength": 1 },
        "role": { "type": ["string", "null"] },
        "trust_score": { "type": ["number", "null"] },
        "network_endpoint": {
          "type": ["object", "null"]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_id", "role", "stream_id", "stream_index", "network_endpoint"],
      "properties": {
        "logical_id": { "type": "string", "minLength": 1 },
        "role": { "type": ["string", "null"] },
        "stream_id": { "type": ["string", "null"] },
        "stream_index": { "type": ["integer", "null"] },
        "network_endpoint": {
          "type": ["object", "null"]
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_name", "raw_identifier", "raw_arguments", "raw_argument_representation"],
      "properties": {
        "raw_name": { "type": ["string", "null"] },
        "raw_identifier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["service_name", "native_service_id", "native_command_id"],
          "properties": {
            "service_name": { "type": ["string", "null"] },
            "native_service_id": { "type": ["number", "null"] },
            "native_command_id": { "type": ["number", "null"] }
          }
        },
        "raw_arguments": {},
        "raw_argument_representation": {}
      }
    },
    "transactionTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_at_ms",
        "request_forwarded_at_ms",
        "protocol_response_at_ms",
        "finalized_at_ms",
        "latency_ms"
      ],
      "properties": {
        "submitted_at_ms": { "type": ["number", "null"] },
        "request_forwarded_at_ms": { "type": ["number", "null"] },
        "protocol_response_at_ms": { "type": ["number", "null"] },
        "finalized_at_ms": { "type": ["number", "null"] },
        "latency_ms": { "type": ["number", "null"] }
      }
    },
    "transactionTransport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport_family", "request_bytes_on_wire", "response_bytes_on_wire"],
      "properties": {
        "transport_family": { "type": ["string", "null"] },
        "request_bytes_on_wire": { "type": ["number", "null"] },
        "response_bytes_on_wire": { "type": ["number", "null"] }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_on_wire",
        "capture_backend",
        "capture_interface",
        "timestamp_source",
        "bytes_source",
        "source_artifact_paths"
      ],
      "properties": {
        "observed_on_wire": { "type": "boolean" },
        "capture_backend": { "type": ["string", "null"] },
        "capture_interface": { "type": ["string", "null"] },
        "timestamp_source": { "type": ["string", "null"] },
        "bytes_source": { "type": ["string", "null"] },
        "source_artifact_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted",
        "executed_successfully",
        "timed_out",
        "raw_code",
        "raw_reason",
        "warning_count",
        "error_count",
        "response_direction_seen",
        "terminal_observed_on_wire",
        "raw_event_name"
      ],
      "properties": {
        "accepted": { "type": ["boolean", "null"] },
        "executed_successfully": { "type": ["boolean", "null"] },
        "timed_out": { "type": ["boolean", "null"] },
        "raw_code": { "type": ["number", "null"] },
        "raw_reason": { "type": ["string", "null"] },
        "warning_count": { "type": ["number", "null"] },
        "error_count": { "type": ["number", "null"] },
        "response_direction_seen": { "type": ["boolean", "null"] },
        "terminal_observed_on_wire": { "type": ["boolean", "null"] },
        "raw_event_name": { "type": ["string", "null"] }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "episode_id", "session_id", "transaction_id", "send_id", "stream_id", "stream_index"],
      "properties": {
        "run_id": { "type": ["integer", "null"] },
        "episode_id": { "type": ["integer", "null"] },
        "session_id": { "type": ["string", "null"] },
        "transaction_id": { "type": ["string", "null"] },
        "send_id": { "type": ["string", "null"] },
        "stream_id": { "type": ["string", "null"] },
        "stream_index": { "type": ["integer", "null"] }
      }
    },
    "evaluationContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "label_name", "attack_family", "phase", "actor_id", "actor_role", "actor_trust"],
      "properties": {
        "label": { "type": ["integer", "null"] },
        "label_name": { "type": ["string", "null"] },
        "attack_family": { "type": ["string", "null"] },
        "phase": { "type": ["string", "null"] },
        "actor_id": { "type": ["string", "null"] },
        "actor_role": { "type": ["string", "null"] },
        "actor_trust": { "type": ["number", "null"] }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "related_packet_count",
        "observed_message_families",
        "observed_message_stages",
        "packet_timestamp_sources",
        "packet_byte_sources",
        "request_wire_observed",
        "response_wire_observed",
        "log_correlation_mode",
        "source_artifact_paths"
      ],
      "properties": {
        "related_packet_count": { "type": "integer", "minimum": 0 },
        "observed_message_families": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observed_message_stages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "packet_timestamp_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "packet_byte_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "request_wire_observed": { "type": "boolean" },
        "response_wire_observed": { "type": "boolean" },
        "log_correlation_mode": { "type": "string", "minLength": 1 },
        "source_artifact_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "nativeStateSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_logical_id", "peer_logical_id", "snapshot_observed_at_ms", "target_fields", "peer_fields"],
      "properties": {
        "target_logical_id": { "type": ["string", "null"] },
        "peer_logical_id": { "type": ["string", "null"] },
        "snapshot_observed_at_ms": { "type": ["number", "null"] },
        "target_fields": { "type": "object" },
        "peer_fields": { "type": "object" }
      }
    }
  }
}
